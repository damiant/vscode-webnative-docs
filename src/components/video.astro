---
interface Props {
  src: string;
  alt?: string;
  aspectRatio?: string;
  autoplay?: boolean;
  controls?: boolean;
  loop?: boolean;
  muted?: boolean;
  borderRadius?: string;
  width?: string;
}

const { 
  src, 
  alt = "Video",
  aspectRatio = "2.7 / 2",
  autoplay = true, 
  controls = true, 
  loop = true, 
  muted = false,
  borderRadius = "0.5rem",
  width = "100%"
} = Astro.props;
---

<div class="video-container">
  <video 
    width={width}
    {autoplay} 
    {controls} 
    {loop}    
    style={`aspect-ratio: ${aspectRatio}; border-radius: ${borderRadius}`}
    playsinline>
    <source src={src} type="video/mp4" />
    {alt && <p>{alt}</p>}
    Your browser does not support the video tag.
  </video>
</div>

<style>
  .video-container {
    margin: 0;
  }
  
  video {
    display: block;
    max-width: 100%;
  }
</style>
